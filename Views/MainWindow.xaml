<Window x:Class="ImageBatchProcessor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageBatchProcessor"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
            <Button Content="Select Image Folder" 
                    Command="{Binding SelectFolderCommand}"
                    Margin="5,10,5,10" />
            <ComboBox ItemsSource="{Binding AvailableTransforms}"
                      SelectedItem="{Binding SelectedTransform}"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Margin="5,10,5,10" />
            <Button Content="Convert" 
                    Command="{Binding ConvertCommand}"
                    Margin="5,10,5,10" />

        </StackPanel>

        
        <DataGrid Grid.Column="1" Grid.Row="0"
                  Grid.RowSpan="3"
                  Margin="5"
                  ItemsSource="{Binding ImageFiles}"
                  SelectedItem="{Binding SelectedImage}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None">

            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding OpenImageCommand}" />
            </DataGrid.InputBindings>
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Name" Width="3*"
                                    Binding="{Binding FileName}" />
                <DataGridTextColumn Header="Extension" Width="*"
                                    Binding="{Binding Extension}" />
                <DataGridTextColumn Header="Size" Width="*"
                                    Binding="{Binding FormattedSize, StringFormat={}{0:N0}}"
                                    SortMemberPath="FileSize"/>
            </DataGrid.Columns>
        </DataGrid>

        
        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
            <TextBlock Text="Preview" 
                       FontWeight="SemiBold"
                       FontSize="10"
                       Margin="5" />
            <Border BorderBrush="LightGray" BorderThickness="1"
                    Background="#F5F5F5" Margin="5"
                    Height="140">
                <Grid>
                    <!-- Placeholder -->
                    <TextBlock Text="Select an image to preview"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Silver" FontSize="8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PreviewImage}" 
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Image Preview -->
                    <Image Source="{Binding PreviewImage}" 
                           Stretch="Uniform" 
                           Margin="4" />
                </Grid>
            </Border>

            <TextBlock FontSize="10" Margin="5,0,5,0">
                <TextBlock.Text>
                    <Binding Path="SelectedImage.FileName" 
                             StringFormat="Name:  {0}"
                             FallbackValue="Name: —" />
                </TextBlock.Text>
            </TextBlock>

            <TextBlock FontSize="10" Margin="5,2,5,0">
                <TextBlock.Text>
                    <Binding Path="SelectedImage.Width" 
                             StringFormat="Width:  {0}px"
                             FallbackValue="Width: —" />
                </TextBlock.Text>
            </TextBlock>

            <TextBlock FontSize="10" Margin="5,2,5,0">
                <TextBlock.Text>
                    <Binding Path="SelectedImage.Height" 
                             StringFormat="Height: {0}px"
                             FallbackValue="Height: —" />
                </TextBlock.Text>
            </TextBlock>

            <TextBlock FontSize="10" Margin="5,2,5,0">
                <TextBlock.Text>
                    <Binding Path="SelectedImage.CreatedDate" 
                             StringFormat="Created: {0:MMM dd, yyyy}"
                             FallbackValue="Created: —" />
                </TextBlock.Text>
            </TextBlock>

        </StackPanel>


        <TextBlock Grid.Column="0" Grid.Row="5" HorizontalAlignment="Center" Text="{Binding SelectedFolderPath}" />
        <TextBlock Grid.Column="1" Grid.Row="5" HorizontalAlignment="Center" Text="{Binding StatusMessage}" />

        <ProgressBar Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3"
                     Height="20"
                     Value="{Binding ProgressPercent}"
                     Minimum="0" Maximum="100">
        </ProgressBar>

    </Grid>
</Window>
